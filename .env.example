# Copier ce fichier vers `.env` et remplir avec vos clés EmailJS (dashboard.emailjs.com).
# Les variables doivent être préfixées VITE_ pour être exposées au front par Vite.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PRODUCT_IMAGES_BUCKET=product-images

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Numéro WhatsApp boutique (format 216XXXXXXXX, sans +). Redémarrer le serveur dev après modification.
VITE_SHOP_WHATSAPP=21620780741
